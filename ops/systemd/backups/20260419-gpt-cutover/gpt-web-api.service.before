[Unit]
Description=Local ChatGPT web API via browser session
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/.ductor/workspace/gpt_web_api
Environment=GPT_WEB_API_HOST=127.0.0.1
Environment=GPT_WEB_API_PORT=4242
Environment=GPT_WEB_API_CDP=http://127.0.0.1:9222
ExecStart=/usr/local/bin/node /root/.ductor/workspace/gpt_web_api/server.mjs
Restart=on-failure
RestartSec=3
LimitNOFILE=100000

[Install]
WantedBy=multi-user.target
